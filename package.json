{
  "name": "simple-voice-recorder",
  "displayName": "Simple Voice Recorder",
  "artifactName": "Simple-Voice-Recorder",
  "version": "1.0.0",
  "private": true,
  "description": "A lightweight portable voice recorder for Windows built with Tauri.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aki-sho/simple-voice-recorder.git"
  },
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "portable:dev": "cargo run --manifest-path src-tauri/Cargo.toml --features portable",
    "portable:build": "cargo build --manifest-path src-tauri/Cargo.toml --release --features portable",
    "release:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-release.ps1",
    "verify:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-release.ps1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  },
  "dependencies": {
    "lamejs": "^1.2.1"
  }
}
